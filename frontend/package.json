{
  "private": true,
  "name": "linkspot-frontend",
  "version": "1.0.0",
  "description": "LinkSpot satellite visibility frontend with anymap-ts",
  "scripts": {
    "build": "esbuild src/anymap-bridge.js --bundle --format=iife --global-name=AnymapModule --outfile=js/anymap-bundle.js --loader:.css=css --loader:.png=dataurl --target=es2020",
    "build:prod": "esbuild src/anymap-bridge.js --bundle --format=iife --global-name=AnymapModule --outfile=js/anymap-bundle.js --loader:.css=css --loader:.png=dataurl --target=es2020 --minify",
    "watch": "esbuild src/anymap-bridge.js --bundle --format=iife --global-name=AnymapModule --outfile=js/anymap-bundle.js --loader:.css=css --loader:.png=dataurl --target=es2020 --watch"
  },
  "dependencies": {
    "anymap-ts": "github:opengeos/anymap-ts"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "@anywidget/types": "^0.2.0"
  }
}
