# =============================================================================
# LinkSpot Backend .dockerignore
# Backend-specific Docker ignore patterns
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/

# Virtual environments
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment files
.env
.env.local
.env.*.local
!.env.example

# Test files
tests/
test/
*_test.py
*_tests.py
test_*.py
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Documentation
*.md
!README.md
docs/

# Local data (should use volumes)
data/
*.geojson
*.json
*.csv
*.pbf
*.osm

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# Build artifacts
*.tar.gz
*.zip

# Git
.git
.gitignore
.gitattributes

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Large binary files
*.pkl
*.pickle
*.h5
*.hdf5
*.model
