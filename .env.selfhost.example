# Copy this file to .env.selfhost and update values before deploy.

POSTGRES_DB=linkspot
POSTGRES_USER=linkspot
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD

# Optional. If omitted, DATABASE_URL is derived from POSTGRES_* values.
# DATABASE_URL=postgresql://linkspot:CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD@postgres:5432/linkspot

REDIS_URL=redis://redis:6379/0

APP_ENV=production
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=true

CORS_ORIGINS=https://www.starpark.app,https://starpark.app

BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=8000

TLE_CACHE_TTL=14400
BUILDING_CACHE_TTL=86400
MIN_ELEVATION=25.0
SATELLITE_THRESHOLD=4

# Optional external service settings
N2YO_API_KEY=
CELESTRAK_API_URL=https://celestrak.org/NORAD/elements/

# Local pgrok tunnel settings
PGROK_REPO=/Users/core/Documents/pgrok
PGROK_SUBDOMAIN=api
EXPECTED_PGROK_DOMAIN=starpark.app
