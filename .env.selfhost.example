# StarPark self-hosted backend configuration
# Copy to .env.selfhost and replace placeholder secrets before use.

POSTGRES_DB=linkspot
POSTGRES_USER=linkspot
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD

BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=8000
ALLOW_PUBLIC_BIND=false

APP_ENV=production
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false
RATE_LIMIT_ENABLED=true

# Netlify frontend origins
CORS_ORIGINS=https://www.starpark.app,https://starpark.app

TLE_CACHE_TTL=14400
BUILDING_CACHE_TTL=86400
MIN_ELEVATION=25.0
SATELLITE_THRESHOLD=4

# Optional upstream credentials
N2YO_API_KEY=
CELESTRAK_API_URL=https://celestrak.org/NORAD/elements/

# pgrok tunnel settings
PGROK_REPO=/Users/core/Documents/pgrok
PGROK_SUBDOMAIN=api
PGROK_BIN=
EXPECTED_PGROK_DOMAIN=coresapian.com
